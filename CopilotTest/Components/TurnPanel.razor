@using CopilotTest.Models
@using CopilotTest.Services
@inject CombatEngineService Combat
@inject PlayerSeat Seat

@* Guide-style "On Your Turn" panel, wired to the shared combat engine. Each rollable
   action runs through PlayerAction/DmActOnCurrent — turn-gated, with auto advantage/
   resistance/concentration, applied to the chosen target and synced to everyone. *@
<div class="lc-panel lc-me">
    <h4>@(IsMyTurn ? "Your turn" : $"You control {Actor.Name}") — pick a target, then an action</h4>

    @{ var abilities = AbilitiesFor(Actor); }
    @if (abilities.Any())
    {
        <div class="lc-row">
            <span class="lc-dim">Abilities:</span>
            @foreach (var ab in abilities)
            {
                var on = Actor.Effects.Any(e => e.Name == ab.Name);
                <button class="btn btn-sm @(on ? "btn-start" : "btn-reset")" title="@ab.Blurb"
                        @onclick="() => Combat.ToggleAdvantageAbility(Actor.Id, ab.Name)">@(on ? "✓ " : "")@ab.Name</button>
            }
        </div>
    }

    <div class="lc-row">
        <span class="lc-dim">Roll:</span>
        <button class="btn btn-sm @(advMode == AdvantageMode.Normal ? "btn-start" : "btn-reset")" @onclick="() => advMode = AdvantageMode.Normal">Normal</button>
        <button class="btn btn-sm @(advMode == AdvantageMode.Advantage ? "btn-start" : "btn-reset")" @onclick="() => advMode = AdvantageMode.Advantage">Advantage</button>
        <button class="btn btn-sm @(advMode == AdvantageMode.Disadvantage ? "btn-start" : "btn-reset")" @onclick="() => advMode = AdvantageMode.Disadvantage">Disadvantage</button>
        <span class="lc-dim">· conditions add their own automatically</span>
    </div>

    <div class="lc-row lc-targets">
        <span class="lc-dim">Target:</span>
        @foreach (var t in Targets)
        {
            <button class="btn btn-sm @(selectedTargetId == t.Id ? "btn-start" : "btn-reset")"
                    @onclick="() => selectedTargetId = t.Id">@t.Name (@t.StatusDisplay)</button>
        }
        @if (!Targets.Any())
        {
            <span class="lc-hint">No valid targets.</span>
        }
    </div>

    <div class="turn-grid">
        @foreach (var col in Columns)
        {
            var items = Bucket(col.Label).Where(a => a.CanUse).ToList();
            <div class="turn-col">
                <div class="turn-col-head">@col.Icon @col.Label <span class="turn-col-sub">@col.Sub</span></div>

                @foreach (var a in items)
                {
                    var rollable = IsRollable(a);
                    <button type="button" class="turn-item @(rollable ? "rollable" : "muted")"
                            disabled="@(rollable && selectedTargetId == null)" @onclick="() => Act(a)">
                        <span class="turn-name">@a.DisplayName @(rollable ? "🎲" : "")</span>
                        <span class="turn-detail">@a.ShortSummary</span>
                    </button>
                }

                @if (col.Label == "Reaction")
                {
                    @if (Actor.ReactionAvailable)
                    {
                        <button type="button" class="turn-item rollable" @onclick="() => Combat.UseReaction(Actor.Id)">
                            <span class="turn-name">⚡ Use Reaction</span>
                            <span class="turn-detail">mark your reaction spent this round</span>
                        </button>
                    }
                    else
                    {
                        <div class="turn-item muted"><span class="turn-detail">Reaction already used</span></div>
                    }
                }
                else if (!items.Any())
                {
                    <div class="turn-item muted"><span class="turn-detail">—</span></div>
                }
            </div>
        }
    </div>

    <p class="lc-hint">Take your action, a bonus action, extra attacks — then end the turn.</p>
    <button class="btn btn-start" @onclick="EndTurn">✓ End Turn</button>
</div>

@code {
    [Parameter, EditorRequired] public Combatant Actor { get; set; } = default!;
    [Parameter] public Character? Template { get; set; }
    [Parameter] public List<Combatant> Targets { get; set; } = new();

    private Guid? selectedTargetId;
    private AdvantageMode advMode = AdvantageMode.Normal;

    private bool IsMyTurn => Seat.CharacterId == Actor.Id && Combat.IsCurrentTurn(Actor.Id);
    private bool IsDm => Seat.Role == SeatRole.Dm;

    private static readonly (string Label, string Sub, string Icon)[] Columns =
    {
        ("Action", "one per turn", "⚔️"),
        ("Bonus Action", "one per turn", "⚡"),
        ("Reaction", "one per round", "🛡️"),
    };

    // Bucket the live actions by action economy, using the Character template's spell
    // casting times when available; weapon attacks and anything unknown fall under Action.
    private List<CombatAction> Bucket(string label)
    {
        var list = new List<CombatAction>();
        foreach (var a in Actor.Actions)
        {
            var bucket = "Action";
            if (a.ActionType != ActionType.Attack && Template != null)
            {
                var sp = Template.Spells.FirstOrDefault(s => s.Name == a.Name);
                if (sp != null) bucket = CastingBucket(sp.CastingTime);
            }
            if (bucket == label) list.Add(a);
        }
        return list;
    }

    private static string CastingBucket(string castingTime)
    {
        var ct = (castingTime ?? "").ToLowerInvariant();
        if (ct.Contains("bonus")) return "Bonus Action";
        if (ct.Contains("reaction")) return "Reaction";
        return "Action";
    }

    private static bool IsRollable(CombatAction a) =>
        a.AttackBonus != 0 || a.SaveDC > 0 || !string.IsNullOrEmpty(a.DamageDice);

    private static List<AdvantageAbility> AbilitiesFor(Combatant c)
    {
        var r = new List<AdvantageAbility>();
        foreach (var f in c.Features)
            if (CombatRules.AdvantageAbilities.TryGetValue(f.Name, out var a) && !r.Contains(a)) r.Add(a);
        return r;
    }

    private void Act(CombatAction a)
    {
        // Rollable actions need a target; utility/buff actions just log their use.
        Combatant? target = IsRollable(a)
            ? Targets.FirstOrDefault(t => t.Id == selectedTargetId)
            : Actor;
        if (target == null) return;

        if (IsMyTurn) Combat.PlayerAction(Actor.Id, a, target, advMode);
        else if (IsDm) Combat.DmActOnCurrent(a, target, advMode);
        // Keep the target & advantage selected so you can take extra attacks / a bonus action.
    }

    private void EndTurn()
    {
        if (IsMyTurn) Combat.EndTurn(Actor.Id);
        else if (IsDm) Combat.NextTurn();
        selectedTargetId = null;
        advMode = AdvantageMode.Normal;
    }
}
