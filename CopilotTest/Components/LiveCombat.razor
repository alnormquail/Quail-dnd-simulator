@using CopilotTest.Models
@using CopilotTest.Services
@inject CombatEngineService Combat
@inject PlayerSeat Seat
@inject SeatRegistry Seats
@implements IDisposable

<div class="live-combat">

    @* ── Setup (DM builds the encounter; players wait) ──────────────────── *@
    @if (Combat.State == CombatState.Setup)
    {
        @if (IsDm)
        {
            <div class="lc-panel">
                <div class="lc-row">
                    <button class="btn btn-action" @onclick="() => Combat.NewEncounter()">↻ Load Party</button>
                    <button class="btn btn-start" disabled="@(Combatants.Count < 2)" @onclick="() => Combat.StartCombat()">⚔️ Start Combat</button>
                </div>
                <p class="lc-hint">Load the party, add monsters below, then Start Combat. Needs at least 2 combatants.</p>
            </div>
            <AddCombatantForm />
            <div class="lc-panel">
                <h3>In the encounter (@Combatants.Count)</h3>
                @foreach (var c in Combatants)
                {
                    <div class="lc-init-row">
                        <span>@TypeIcon(c) <strong>@c.Name</strong> <span class="lc-dim">@c.ClassDisplay</span></span>
                        <button class="btn btn-reset btn-sm" @onclick="() => Combat.RemoveCombatant(c.Id)">✕</button>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="lc-panel lc-waiting">
                <h3>⏳ Waiting for the DM to start combat…</h3>
                <p class="lc-hint">You're seated as <strong>@Seat.Label</strong>. The encounter will appear here the moment it begins.</p>
            </div>
        }
    }
    else
    {
        @* ── Active / Finished encounter ───────────────────────────────── *@
        <div class="lc-panel lc-status-bar">
            <div>
                <span class="lc-round">Round @Combat.CurrentRound</span>
                @if (Combat.State == CombatState.Finished)
                {
                    <span class="lc-turn">🏁 Combat over</span>
                }
                else
                {
                    <span class="lc-turn">▶ @Combat.CurrentCombatant?.Name's turn</span>
                }
            </div>
            @if (IsDm && Combat.State == CombatState.Active)
            {
                <div class="lc-row">
                    <button class="btn btn-action" @onclick="() => Combat.NextTurn()">⏭ Next Turn</button>
                    <button class="btn btn-reset" @onclick="() => Combat.EndCombat()">🏁 End</button>
                </div>
            }
        </div>

        @* Initiative order *@
        <div class="lc-panel">
            <h3>Initiative</h3>
            @foreach (var c in Combatants)
            {
                var isCurrent = Combat.State == CombatState.Active && Combat.CurrentCombatant?.Id == c.Id;
                var isMe = MyId == c.Id;
                <div class="lc-init-row @(isCurrent ? "lc-current" : "") @(c.CurrentHitPoints <= 0 ? "lc-down" : "")">
                    <div class="lc-init-main">
                        <span class="lc-init-num">@(c.Initiative)</span>
                        <span>@TypeIcon(c) <strong>@c.Name</strong>@(isMe ? " (you)" : "")</span>
                        @if (!c.ReactionAvailable)
                        {
                            <span class="lc-dim" title="Reaction used">⚡︎</span>
                        }
                    </div>
                    <div class="lc-init-status">
                        @if (CanSeeExactHp(c))
                        {
                            <span class="lc-hp">@c.HpDisplay</span>
                        }
                        else
                        {
                            <span class="lc-hp">@c.StatusDisplay</span>
                        }
                    </div>
                    @if (c.Conditions.Any() || c.IsRaging || c.Effects.Any())
                    {
                        <div class="lc-conditions">
                            @if (c.IsRaging)
                            {
                                <span class="lc-cond">🔥 Raging</span>
                            }
                            @foreach (var cond in c.Conditions)
                            {
                                <span class="lc-cond">@cond</span>
                            }
                            @foreach (var fx in c.Effects)
                            {
                                <span class="lc-effect">
                                    ✨ @fx.Label
                                    @if (IsDm)
                                    {
                                        <button class="lc-effect-x" title="Remove" @onclick="() => Combat.RemoveEffect(c.Id, fx.Id)">✕</button>
                                    }
                                </span>
                            }
                        </div>
                    }
                    @if (c.Immunities.Any() || c.Resistances.Any() || c.Vulnerabilities.Any())
                    {
                        <div class="lc-conditions">
                            @foreach (var t in c.Immunities) { <span class="lc-cond" title="Immune">🛡️ @t</span> }
                            @foreach (var t in c.Resistances) { <span class="lc-cond" title="Resistant">½ @t</span> }
                            @foreach (var t in c.Vulnerabilities) { <span class="lc-cond" title="Vulnerable">×2 @t</span> }
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(c.ConcentratingOn))
                    {
                        <div class="lc-conditions">
                            <span class="lc-effect" title="Concentrating">
                                🧠 @c.ConcentratingOn
                                @if (IsDm || MyId == c.Id)
                                {
                                    <button class="lc-effect-x" title="Drop concentration" @onclick="() => Combat.DropConcentration(c.Id)">✕</button>
                                }
                            </span>
                        </div>
                    }

                    @* DM per-combatant controls *@
                    @if (IsDm && Combat.State == CombatState.Active)
                    {
                        <div class="lc-dm-controls">
                            <button class="btn btn-sm btn-reset" @onclick="() => Combat.AdjustHp(c.Id, -5)">-5</button>
                            <button class="btn btn-sm btn-reset" @onclick="() => Combat.AdjustHp(c.Id, -1)">-1</button>
                            <button class="btn btn-sm btn-action" @onclick="() => Combat.AdjustHp(c.Id, 1)">+1</button>
                            <button class="btn btn-sm btn-action" @onclick="() => Combat.AdjustHp(c.Id, 5)">+5</button>
                            <select class="form-input lc-cond-select" @onchange="(e) => OnToggleCondition(c.Id, e)">
                                <option value="">+ condition…</option>
                                @foreach (var cond in AllConditions)
                                {
                                    <option value="@cond">@(c.Conditions.Contains(cond) ? "✓ " : "")@cond</option>
                                }
                            </select>
                            @if (c.Type == CombatantType.PC && c.IsUnconscious)
                            {
                                <button class="btn btn-sm" @onclick="() => Combat.RollDeathSaveFor(c.Id)">🎲 Death save (@c.DeathSaveSuccesses✓/@c.DeathSaveFailures✗)</button>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        @* ── DM: apply a timed effect (auto-expires) ───────────────────────── *@
        @if (IsDm && Combat.State == CombatState.Active)
        {
            <div class="lc-panel">
                <h3>Apply a timed effect</h3>
                <div class="lc-row">
                    <select class="form-input" @bind="fxTargetId">
                        <option value="">Who…</option>
                        @foreach (var c in Combatants)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                    <input class="form-input" style="width:140px" placeholder="Effect (e.g. Hex)" @bind="fxName" />
                    <select class="form-input lc-cond-select" @bind="fxCondition">
                        <option value="">no condition</option>
                        @foreach (var cond in AllConditions)
                        {
                            <option value="@cond">imposes @cond</option>
                        }
                    </select>
                    <input class="form-input" type="number" min="1" style="width:64px" @bind="fxRounds" /> <span class="lc-dim">rounds</span>
                    <button class="btn btn-sm btn-action" @onclick="ApplyEffect">+ Add</button>
                    <button class="btn btn-sm" @onclick="SetConcFromForm" title="Mark the chosen combatant concentrating on the typed name">🧠 Concentrate</button>
                </div>
                <p class="lc-hint">Effects count down at the start of each round and clear themselves (and any condition they impose) when they expire.</p>
            </div>

            <div class="lc-panel">
                <h3>Damage modifiers</h3>
                <div class="lc-row">
                    <select class="form-input" @bind="dmTargetId">
                        <option value="">Who…</option>
                        @foreach (var c in Combatants)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                    <select class="form-input lc-cond-select" @bind="dmType">
                        @foreach (var t in DamageTypes)
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                    <button class="btn btn-sm btn-reset" @onclick="() => ToggleDmg(DamageMod.Resistance)">½ Resist</button>
                    <button class="btn btn-sm btn-reset" @onclick="() => ToggleDmg(DamageMod.Immunity)">🛡️ Immune</button>
                    <button class="btn btn-sm btn-action" @onclick="() => ToggleDmg(DamageMod.Vulnerability)">×2 Vulnerable</button>
                </div>
                <p class="lc-hint">Toggle a type on the chosen combatant: resistance halves it, immunity negates it, vulnerability doubles it.</p>
            </div>
        }

        @* ── Incapacitated: the controlled combatant can't act this turn ──── *@
        @if (Actor != null && Combat.State == CombatState.Active && !Actor.IsUnconscious
             && CombatEngineService.IsIncapacitated(Actor))
        {
            <div class="lc-panel lc-me">
                <h4>@Actor.Name can't act — @IncapLabel(Actor)</h4>
                <p class="lc-hint">Incapacitating conditions block actions, bonus actions, and reactions.</p>
                <button class="btn btn-start" @onclick="EndCurrentTurn">✓ End Turn</button>
            </div>
        }

        @* ── Action panel: shown to whoever controls the current combatant ─ *@
        else if (Actor != null && Combat.State == CombatState.Active && !Actor.IsUnconscious)
        {
            <div class="lc-panel lc-me lc-attack">
                <h4>
                    @(IsMyTurn ? "Your turn" : $"You control {Actor.Name}") — choose a target &amp; action
                </h4>

                <div class="lc-row">
                    <span class="lc-dim">Roll:</span>
                    <button class="btn btn-sm @(advMode == AdvantageMode.Normal ? "btn-start" : "btn-reset")"
                            @onclick="() => advMode = AdvantageMode.Normal">Normal</button>
                    <button class="btn btn-sm @(advMode == AdvantageMode.Advantage ? "btn-start" : "btn-reset")"
                            @onclick="() => advMode = AdvantageMode.Advantage">Advantage</button>
                    <button class="btn btn-sm @(advMode == AdvantageMode.Disadvantage ? "btn-start" : "btn-reset")"
                            @onclick="() => advMode = AdvantageMode.Disadvantage">Disadvantage</button>
                </div>

                <div class="lc-targets">
                    @foreach (var t in Targets)
                    {
                        <button class="btn btn-sm @(selectedTargetId == t.Id ? "btn-start" : "btn-reset")"
                                @onclick="() => selectedTargetId = t.Id">@t.Name (@t.StatusDisplay)</button>
                    }
                </div>
                @if (!Targets.Any())
                {
                    <p class="lc-hint">No valid targets.</p>
                }

                <div class="lc-actions">
                    @foreach (var action in Actor.Actions.Where(a => a.CanUse))
                    {
                        <button class="btn btn-action" disabled="@(selectedTargetId == null)"
                                @onclick="() => DoAction(action)">@action.DisplayName</button>
                    }
                </div>

                <p class="lc-hint">Take your action, bonus action, and any extra attacks — then end the turn.</p>
                <button class="btn btn-start" @onclick="EndCurrentTurn">✓ End Turn</button>
            </div>
        }

        @* ── The player's own character panel ──────────────────────────── *@
        @if (Me != null)
        {
            <div class="lc-panel lc-me">
                <h3>@Me.Name — @Me.HpDisplay</h3>

                @if (Combat.State == CombatState.Active && Me.IsUnconscious)
                {
                    <div class="lc-row">
                        <strong>You're down!</strong>
                        <button class="btn btn-start" @onclick="() => Combat.RollDeathSaveFor(Me.Id)">🎲 Roll Death Save</button>
                        <span>@Me.DeathSaveSuccesses ✓ / @Me.DeathSaveFailures ✗</span>
                    </div>
                }
                else
                {
                    <div class="lc-row lc-self-actions">
                        @if (Me.IsBarbarianClass && !Me.IsRaging && Me.RageUsesRemaining > 0)
                        {
                            <button class="btn btn-action" @onclick="() => Combat.EnterRage(Me)">🔥 Rage (@Me.RageUsesRemaining left)</button>
                        }
                        @if (Me.ReactionAvailable)
                        {
                            <button class="btn btn-sm" @onclick="() => Combat.UseReaction(Me.Id)">⚡ Use Reaction</button>
                        }
                        else
                        {
                            <span class="lc-dim">Reaction used</span>
                        }
                    </div>

                    <div class="lc-row">
                        @if (string.IsNullOrEmpty(Me.ConcentratingOn))
                        {
                            <input class="form-input" style="width:150px" placeholder="Concentrating on…" @bind="concInput" />
                            <button class="btn btn-sm btn-action" @onclick="SetMyConcentration">🧠 Concentrate</button>
                        }
                        else
                        {
                            <span>🧠 Concentrating: <strong>@Me.ConcentratingOn</strong></span>
                            <button class="btn btn-sm btn-reset" @onclick="() => Combat.DropConcentration(Me.Id)">Drop</button>
                        }
                    </div>

                    @if (Me.SpellSlots.Any())
                    {
                        <div class="lc-slots">
                            @foreach (var slot in Me.SpellSlots)
                            {
                                <div class="lc-slot-row">
                                    <span class="lc-dim">Lvl @slot.Level</span>
                                    @for (int i = 1; i <= slot.Max; i++)
                                    {
                                        var pip = i;
                                        var used = pip <= slot.Used;
                                        <button class="lc-pip @(used ? "lc-pip-used" : "")"
                                                @onclick="() => Combat.SetSlotUsed(Me.Id, slot.Level, used ? pip - 1 : pip)"></button>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @if (Me.Pools.Any())
                    {
                        <div class="lc-pools">
                            @foreach (var pool in Me.Pools)
                            {
                                <span class="lc-pool">@pool.Name: @pool.Current/@pool.Max@(pool.Note is not null ? $" ({pool.Note})" : "")</span>
                            }
                        </div>
                    }
                }

                @if (Combat.State == CombatState.Active && !IsMyTurn && !Me.IsUnconscious)
                {
                    <p class="lc-hint">Waiting — it's <strong>@Combat.CurrentCombatant?.Name</strong>'s turn.</p>
                }
            </div>
        }

        <CombatLogPanel />
    }
</div>

@code {
    private Guid? selectedTargetId;
    private AdvantageMode advMode = AdvantageMode.Normal;

    // DM "apply a timed effect" form state.
    private string fxTargetId = "";
    private string fxName = "";
    private string fxCondition = "";
    private int fxRounds = 3;

    // DM damage-modifier editor state.
    private string dmTargetId = "";
    private DamageType dmType = DamageType.Fire;
    private static readonly DamageType[] DamageTypes =
        Enum.GetValues<DamageType>().Where(t => t != DamageType.None).ToArray();

    private void ToggleDmg(DamageMod mod)
    {
        if (Guid.TryParse(dmTargetId, out var id)) Combat.ToggleDamageMod(id, dmType, mod);
    }

    // Concentration controls.
    private string concInput = "";

    private void SetMyConcentration()
    {
        if (Me != null && !string.IsNullOrWhiteSpace(concInput))
        {
            Combat.SetConcentration(Me.Id, concInput);
            concInput = "";
        }
    }

    private void SetConcFromForm()
    {
        if (Guid.TryParse(fxTargetId, out var id) && !string.IsNullOrWhiteSpace(fxName))
        {
            Combat.SetConcentration(id, fxName);
            fxName = "";
        }
    }

    private bool IsDm => Seat.Role == SeatRole.Dm;
    private Guid? MyId => Seat.CharacterId;
    private Combatant? Me => MyId.HasValue ? Combat.Find(MyId.Value) : null;
    private bool IsMyTurn => MyId.HasValue && Combat.IsCurrentTurn(MyId.Value);

    private IReadOnlyList<Combatant> Combatants => Combat.SnapshotCombatants();
    private List<Combatant> Targets => Combat.GetCurrentTargets();

    private Guid? CurrentId => Combat.CurrentCombatant?.Id;
    private bool CurrentIsClaimed => CurrentId.HasValue && Seats.IsClaimed(CurrentId.Value);

    // The combatant this viewer controls right now: your PC on your turn, or — for the
    // DM — the current combatant whenever no player has claimed it (monsters & unseated PCs).
    private Combatant? Actor
    {
        get
        {
            if (Combat.State != CombatState.Active) return null;
            if (IsMyTurn) return Me;
            if (IsDm && CurrentId.HasValue && !CurrentIsClaimed) return Combat.CurrentCombatant;
            return null;
        }
    }

    private static readonly Condition[] AllConditions =
        Enum.GetValues<Condition>().Where(c => c != Condition.None).ToArray();

    // Monster HP is hidden from players/spectators; PCs are visible to all (table sees each other).
    private bool CanSeeExactHp(Combatant c) => IsDm || c.Type != CombatantType.Monster;

    private void DoAction(CombatAction action)
    {
        if (selectedTargetId == null || Actor == null) return;
        var target = Combatants.FirstOrDefault(c => c.Id == selectedTargetId);
        if (target == null) return;

        if (IsMyTurn && MyId.HasValue)
            Combat.PlayerAction(MyId.Value, action, target, advMode);
        else if (IsDm)
            Combat.DmActOnCurrent(action, target, advMode);
        // Keep the target & advantage selected so you can take extra attacks / a bonus action.
    }

    private void EndCurrentTurn()
    {
        if (IsMyTurn && MyId.HasValue) Combat.EndTurn(MyId.Value);
        else if (IsDm) Combat.NextTurn();
        selectedTargetId = null;
        advMode = AdvantageMode.Normal;
    }

    private void ApplyEffect()
    {
        if (!Guid.TryParse(fxTargetId, out var tid) || string.IsNullOrWhiteSpace(fxName)) return;
        Condition? cond = Enum.TryParse<Condition>(fxCondition, out var cc) && cc != Condition.None ? cc : null;
        Combat.AddEffect(tid, new ActiveEffect
        {
            Name = fxName.Trim(),
            Source = "DM",
            Condition = cond,
            RoundsRemaining = Math.Max(1, fxRounds),
        });
        fxName = "";
        fxCondition = "";
    }

    private void OnToggleCondition(Guid id, ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        if (string.IsNullOrEmpty(val)) return;
        if (Enum.TryParse<Condition>(val, out var cond))
            Combat.ToggleCondition(id, cond);
    }

    private static string IncapLabel(Combatant c)
    {
        var conds = c.Conditions
            .Where(x => x is Condition.Stunned or Condition.Paralyzed or Condition.Incapacitated or Condition.Unconscious)
            .ToList();
        return conds.Count > 0 ? string.Join(", ", conds) : "incapacitated";
    }

    private static string TypeIcon(Combatant c) => c.Type switch
    {
        CombatantType.Monster => "👹",
        CombatantType.NPC => "🧑",
        _ => "🛡️"
    };

    protected override void OnInitialized() => Combat.OnStateChanged += OnChanged;
    private void OnChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Combat.OnStateChanged -= OnChanged;
}
