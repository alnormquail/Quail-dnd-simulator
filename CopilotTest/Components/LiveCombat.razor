@using CopilotTest.Models
@using CopilotTest.Services
@using Microsoft.JSInterop
@inject LiveEncounterService Live
@inject PlayerSeat Seat
@inject SeatRegistry Seats
@inject IJSRuntime JS
@implements IDisposable

<div class="live-combat">

    @* ── Setup (DM builds the encounter; players wait) ──────────────────── *@
    @if (Live.State == CombatState.Setup)
    {
        @if (IsDm)
        {
            <div class="lc-panel">
                <div class="lc-row">
                    <button class="btn btn-action" @onclick="() => Live.NewEncounter()">↻ Load Party</button>
                    <button class="btn btn-start" disabled="@(Combatants.Count < 2)" @onclick="() => Live.StartCombat()">⚔️ Roll Initiative &amp; Start</button>
                </div>
                <p class="lc-hint">Load the party, add monsters below, then start. Initiative is rolled automatically — you can edit any number once combat begins.</p>
            </div>
            <AddCombatantForm OnAdd="Live.AddCombatant" />
            <div class="lc-panel">
                <h3>In the encounter (@Combatants.Count)</h3>
                @foreach (var c in Combatants)
                {
                    <div class="lc-init-row">
                        <span>@TypeIcon(c) <strong>@c.Name</strong> <span class="lc-dim">@c.ClassDisplay</span></span>
                        <button class="btn btn-reset btn-sm" @onclick="() => Live.RemoveCombatant(c.Id)">✕</button>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="lc-panel lc-waiting">
                <h3>⏳ Waiting for the DM to start combat…</h3>
                <p class="lc-hint">You're seated as <strong>@Seat.Label</strong>. The encounter will appear here the moment it begins.</p>
            </div>
        }
    }
    else
    {
        @* ── Active / Finished encounter ───────────────────────────────── *@
        <div class="lc-panel lc-status-bar">
            <div>
                <span class="lc-round">Round @Live.CurrentRound</span>
                @if (Live.State == CombatState.Finished)
                {
                    <span class="lc-turn">🏁 Combat over</span>
                }
                else
                {
                    <span class="lc-turn">▶ @Live.CurrentCombatant?.Name's turn</span>
                }
            </div>
            @if (IsDm)
            {
                <div class="lc-row">
                    @if (Live.State == CombatState.Active)
                    {
                        <button class="btn btn-action" @onclick="() => Live.NextTurn()">⏭ Next Turn</button>
                        <button class="btn btn-reset" @onclick="() => Live.EndCombat()">🏁 End</button>
                    }
                    <button class="btn btn-action" @onclick="() => Live.NewEncounter()">↻ New Encounter</button>
                </div>
            }
        </div>

        @* ── "It's your turn!" banner ──────────────────────────────────── *@
        @if (IsMyTurn && Live.State == CombatState.Active)
        {
            <div class="lc-panel lc-your-turn">
                <h2>🎲 It's your turn, @Me?.Name!</h2>
                <button class="btn btn-start" @onclick="() => Live.EndTurn(MyId!.Value)">✓ End My Turn</button>
            </div>
        }

        @* Initiative order *@
        <div class="lc-panel">
            <h3>Initiative</h3>
            @foreach (var c in Combatants)
            {
                var isCurrent = Live.State == CombatState.Active && Live.CurrentCombatant?.Id == c.Id;
                var isMe = MyId == c.Id;
                <div class="lc-init-row @(isCurrent ? "lc-current" : "") @(c.CurrentHitPoints <= 0 ? "lc-down" : "")">
                    <div class="lc-init-main">
                        @if (IsDm && Live.State == CombatState.Active)
                        {
                            <input class="form-input lc-init-edit" type="number" title="Edit initiative"
                                   value="@c.Initiative"
                                   @onchange="(e) => OnInitiativeEdit(c.Id, e)" />
                        }
                        else
                        {
                            <span class="lc-init-num">@(c.Initiative)</span>
                        }
                        <span>@TypeIcon(c) <strong>@c.Name</strong>@(isMe ? " (you)" : "")</span>
                        @if (!c.ReactionAvailable)
                        {
                            <span class="lc-dim" title="Reaction used">⚡︎</span>
                        }
                    </div>
                    <div class="lc-init-status">
                        @if (CanSeeExactHp(c))
                        {
                            <span class="lc-hp">@c.HpDisplay</span>
                        }
                        else
                        {
                            <span class="lc-hp">@c.StatusDisplay</span>
                        }
                    </div>
                    @if (c.Conditions.Any() || c.IsRaging)
                    {
                        <div class="lc-conditions">
                            @if (c.IsRaging)
                            {
                                <span class="lc-cond">🔥 Raging</span>
                            }
                            @foreach (var cond in c.Conditions)
                            {
                                <span class="lc-cond">@cond</span>
                            }
                        </div>
                    }

                    @* DM per-combatant controls *@
                    @if (IsDm && Live.State == CombatState.Active)
                    {
                        <div class="lc-dm-controls">
                            <button class="btn btn-sm btn-reset" @onclick="() => Live.AdjustHp(c.Id, -5)">-5</button>
                            <button class="btn btn-sm btn-reset" @onclick="() => Live.AdjustHp(c.Id, -1)">-1</button>
                            <button class="btn btn-sm btn-action" @onclick="() => Live.AdjustHp(c.Id, 1)">+1</button>
                            <button class="btn btn-sm btn-action" @onclick="() => Live.AdjustHp(c.Id, 5)">+5</button>
                            <select class="form-input lc-cond-select" @onchange="(e) => OnToggleCondition(c.Id, e)">
                                <option value="">+ condition…</option>
                                @foreach (var cond in AllConditions)
                                {
                                    <option value="@cond">@(c.Conditions.Contains(cond) ? "✓ " : "")@cond</option>
                                }
                            </select>
                            @if (c.Type == CombatantType.PC && c.IsUnconscious)
                            {
                                <button class="btn btn-sm" @onclick="() => Live.RollDeathSaveFor(c.Id)">🎲 Death save (@c.DeathSaveSuccesses✓/@c.DeathSaveFailures✗)</button>
                                <button class="btn btn-sm btn-action" title="Record a success rolled at the table" @onclick="() => Live.RecordDeathSave(c.Id, true)">+✓</button>
                                <button class="btn btn-sm btn-reset" title="Record a failure rolled at the table" @onclick="() => Live.RecordDeathSave(c.Id, false)">+✗</button>
                                <button class="btn btn-sm" title="Reset death saves (e.g. stabilized)" @onclick="() => Live.ClearDeathSaves(c.Id)">↺</button>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        @* ── DM: view any character's guide ────────────────────────────── *@
        @if (IsDm)
        {
            <div class="lc-panel">
                <div class="lc-row">
                    <h3 style="margin:0">📖 Character Guides</h3>
                    <select class="form-input" @onchange="OnPickGuide">
                        <option value="">View a character's guide…</option>
                        @foreach (var pc in GuidePcs)
                        {
                            <option value="@pc.Id" selected="@(_dmGuideId == pc.Id)">@pc.Name — @pc.ClassDisplay</option>
                        }
                    </select>
                </div>
            </div>
            @if (DmGuideHero != null)
            {
                <GuidePanel Hero="DmGuideHero" />
            }
        }

        @* ── Your character guide, shown on your turn ──────────────────── *@
        @if (IsMyTurn && Live.State == CombatState.Active && Me is { IsUnconscious: false })
        {
            @if (MyTemplate != null && GuidePanel.HasGuide(MyTemplate.Id))
            {
                <GuidePanel Hero="MyTemplate" />
            }
            else
            {
                <div class="lc-panel lc-me">
                    <p class="lc-hint">No character guide available for @Me?.Name yet — play from your sheet, and tell the table what you do!</p>
                </div>
            }
        }

        @* ── The player's own quick panel ──────────────────────────────── *@
        @if (Me != null)
        {
            <div class="lc-panel lc-me">
                <h3>@Me.Name — @Me.HpDisplay</h3>

                @if (Live.State == CombatState.Active && Me.IsUnconscious)
                {
                    <div class="lc-row">
                        <strong>You're down!</strong>
                        <button class="btn btn-start" @onclick="() => Live.RollDeathSaveFor(Me.Id)">🎲 Roll Death Save</button>
                        <span>@Me.DeathSaveSuccesses ✓ / @Me.DeathSaveFailures ✗</span>
                    </div>
                }
                else
                {
                    <div class="lc-row lc-self-actions">
                        @if (Me.IsBarbarianClass)
                        {
                            @if (Me.IsRaging)
                            {
                                <button class="btn btn-reset" @onclick="() => Live.ToggleRaging(Me.Id)">🔥 End Rage</button>
                            }
                            else if (Me.RageUsesRemaining > 0)
                            {
                                <button class="btn btn-action" @onclick="() => Live.ToggleRaging(Me.Id)">🔥 Rage (@Me.RageUsesRemaining left)</button>
                            }
                        }
                        @if (Me.ReactionAvailable)
                        {
                            <button class="btn btn-sm" @onclick="() => Live.UseReaction(Me.Id)">⚡ Use Reaction</button>
                        }
                        else
                        {
                            <span class="lc-dim">Reaction used</span>
                        }
                    </div>

                    @if (Me.SpellSlots.Any())
                    {
                        <div class="lc-slots">
                            @foreach (var slot in Me.SpellSlots)
                            {
                                <div class="lc-slot-row">
                                    <span class="lc-dim">Lvl @slot.Level</span>
                                    @for (int i = 1; i <= slot.Max; i++)
                                    {
                                        var pip = i;
                                        var used = pip <= slot.Used;
                                        <button class="lc-pip @(used ? "lc-pip-used" : "")"
                                                @onclick="() => Live.SetSlotUsed(Me.Id, slot.Level, used ? pip - 1 : pip)"></button>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @if (Me.Pools.Any())
                    {
                        <div class="lc-pools">
                            @foreach (var pool in Me.Pools)
                            {
                                <span class="lc-pool">@pool.Name: @pool.Current/@pool.Max@(pool.Note is not null ? $" ({pool.Note})" : "")</span>
                            }
                        </div>
                    }
                }

                @if (Live.State == CombatState.Active && !IsMyTurn && !Me.IsUnconscious)
                {
                    <p class="lc-hint">Waiting — it's <strong>@Live.CurrentCombatant?.Name</strong>'s turn.</p>
                }
            </div>
        }

        @* ── Encounter log ─────────────────────────────────────────────── *@
        <div class="lc-panel">
            <h3>📜 Log</h3>
            <div class="combat-log lc-log">
                @foreach (var entry in LogEntries.Reverse())
                {
                    <div class="log-entry @Live.GetEntryClass(entry.EntryType)">
                        <span class="log-icon">@Live.GetEntryIcon(entry.EntryType)</span>
                        <span class="log-round">R@(entry.Round)</span>
                        <span class="log-text"><strong>@entry.ActorName</strong> @entry.Message</span>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private Character? MyTemplate =>
        MyId.HasValue ? Live.SavedRoster.FirstOrDefault(t => t.Id == MyId.Value) : null;

    // DM guide viewer: which party member's guide the DM is currently reading.
    private Guid? _dmGuideId;
    private IEnumerable<Character> GuidePcs => Live.SavedRoster.Where(c => GuidePanel.HasGuide(c.Id));
    private Character? DmGuideHero =>
        _dmGuideId.HasValue ? Live.SavedRoster.FirstOrDefault(c => c.Id == _dmGuideId.Value) : null;
    private void OnPickGuide(ChangeEventArgs e) =>
        _dmGuideId = Guid.TryParse(e.Value?.ToString(), out var g) ? g : null;

    private bool IsDm => Seat.Role == SeatRole.Dm;
    private Guid? MyId => Seat.CharacterId;
    private Combatant? Me => MyId.HasValue ? Live.Find(MyId.Value) : null;
    private bool IsMyTurn => MyId.HasValue && Live.IsCurrentTurn(MyId.Value);

    private IReadOnlyList<Combatant> Combatants => Live.SnapshotCombatants();
    private IReadOnlyList<CombatLog> LogEntries => Live.SnapshotLog();

    private static readonly Condition[] AllConditions =
        Enum.GetValues<Condition>().Where(c => c != Condition.None).ToArray();

    // Monster HP is hidden from players/spectators; PCs are visible to all (table sees each other).
    private bool CanSeeExactHp(Combatant c) => IsDm || c.Type != CombatantType.Monster;

    private void OnInitiativeEdit(Guid id, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
            Live.SetInitiative(id, val);
    }

    private void OnToggleCondition(Guid id, ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        if (string.IsNullOrEmpty(val)) return;
        if (Enum.TryParse<Condition>(val, out var cond))
            Live.ToggleCondition(id, cond);
    }

    private static string TypeIcon(Combatant c) => c.Type switch
    {
        CombatantType.Monster => "👹",
        CombatantType.NPC => "🧑",
        _ => "🛡️"
    };

    // ── Turn notification: chime once when it BECOMES my turn ───────────────
    private bool _wasMyTurn;

    protected override void OnInitialized()
    {
        Live.OnStateChanged += OnChanged;
        _wasMyTurn = IsMyTurn;
    }

    private void OnChanged() => InvokeAsync(async () =>
    {
        var nowMyTurn = IsMyTurn;
        if (nowMyTurn && !_wasMyTurn)
        {
            try { await JS.InvokeVoidAsync("quailTurnDing"); }
            catch { /* no JS (prerender) or audio blocked — the banner still shows */ }
        }
        _wasMyTurn = nowMyTurn;
        StateHasChanged();
    });

    public void Dispose() => Live.OnStateChanged -= OnChanged;
}
