@if (Hero != null && GuideData.TryGetValue(Hero.Id, out var guide))
{
        <div class="guide-panel">

            <!-- Header -->
            <div class="guide-header">
                <h2>@Hero.Name</h2>
                <p class="guide-subtitle">@Hero.ClassDisplay &bull; @guide.Race &bull; @guide.Background</p>
            </div>

            <!-- Combat Stats Row -->
            <div class="guide-stats-row">
                <div class="guide-stat"><span class="stat-label">AC</span><span class="stat-value">@Hero.ArmorClass</span></div>
                <div class="guide-stat"><span class="stat-label">Max HP</span><span class="stat-value">@Hero.MaxHitPoints</span></div>
                <div class="guide-stat"><span class="stat-label">Speed</span><span class="stat-value">@Hero.Speed ft</span></div>
                <div class="guide-stat"><span class="stat-label">Initiative</span><span class="stat-value">@FormatBonus(Hero.DexterityModifier)</span></div>
                <div class="guide-stat"><span class="stat-label">Proficiency</span><span class="stat-value">@FormatBonus(Hero.ProficiencyBonus)</span></div>
                @if (HasSpells(Hero))
                {
                    var castMod = SpellAbilityMod(Hero);
                    <div class="guide-stat"><span class="stat-label">Spell Save DC</span><span class="stat-value">@(8 + Hero.ProficiencyBonus + castMod)</span></div>
                    <div class="guide-stat"><span class="stat-label">Spell Attack</span><span class="stat-value">@FormatBonus(Hero.ProficiencyBonus + castMod)</span></div>
                }
                @if (Hero.IsBarbarianClass)
                {
                    <div class="guide-stat"><span class="stat-label">Rages/Day</span><span class="stat-value">@Hero.RageUsesPerDay</span></div>
                    <div class="guide-stat"><span class="stat-label">Rage Bonus</span><span class="stat-value">+@Hero.RageBonus dmg</span></div>
                }
            </div>

            <!-- On Your Turn (action economy) -->
            <div class="guide-section">
                <h3>⏱️ On Your Turn</h3>
                <div class="turn-grid">
                    <div class="turn-col turn-action">
                        <div class="turn-col-head">⚔️ Action <span class="turn-col-sub">one per turn</span></div>
                        @foreach (var t in TurnItemsFor(Hero, guide, "Action"))
                        {
                            <div class="turn-item @(t.Highlight ? "feat" : "")"><span class="turn-name">@t.Name</span><span class="turn-detail">@t.Detail</span></div>
                        }
                        <div class="turn-item muted"><span class="turn-name">Standard</span><span class="turn-detail">Dash · Disengage · Dodge · Help · Hide · Ready · Search · Shove · Grapple</span></div>
                    </div>
                    <div class="turn-col turn-bonus">
                        <div class="turn-col-head">⚡ Bonus Action <span class="turn-col-sub">one per turn</span></div>
                        @{ var bonus = TurnItemsFor(Hero, guide, "Bonus Action"); }
                        @if (bonus.Any())
                        {
                            @foreach (var t in bonus)
                            {
                                <div class="turn-item @(t.Highlight ? "feat" : "")"><span class="turn-name">@t.Name</span><span class="turn-detail">@t.Detail</span></div>
                            }
                        }
                        else
                        {
                            <div class="turn-item muted"><span class="turn-detail">Nothing special — see class features.</span></div>
                        }
                    </div>
                    <div class="turn-col turn-reaction">
                        <div class="turn-col-head">🛡️ Reaction <span class="turn-col-sub">one per round</span></div>
                        @foreach (var t in TurnItemsFor(Hero, guide, "Reaction"))
                        {
                            <div class="turn-item @(t.Highlight ? "feat" : "")"><span class="turn-name">@t.Name</span><span class="turn-detail">@t.Detail</span></div>
                        }
                        <div class="turn-item muted"><span class="turn-name">Opportunity Attack</span><span class="turn-detail">when an enemy leaves your reach</span></div>
                    </div>
                    <div class="turn-col turn-move">
                        <div class="turn-col-head">🦶 Movement &amp; Free <span class="turn-col-sub">@Hero.Speed ft</span></div>
                        <div class="turn-item muted"><span class="turn-detail">Move up to @Hero.Speed ft (split around your action).</span></div>
                        <div class="turn-item muted"><span class="turn-detail">Free: drop an item, speak, 1 free object interaction.</span></div>
                        @{ var other = TurnItemsFor(Hero, guide, "Other"); }
                        @foreach (var t in other)
                        {
                            <div class="turn-item @(t.Highlight ? "feat" : "")"><span class="turn-name">@t.Name</span><span class="turn-detail">@t.Detail</span></div>
                        }
                    </div>
                </div>
            </div>

            <!-- Session Tracker -->
            <div class="guide-section tracker-section">
                <h3>🎲 Session Tracker</h3>
                <div class="tracker-grid">

                    <!-- HP -->
                    <div class="tracker-block">
                        <div class="tracker-label">Hit Points</div>
                        <div class="tracker-hp-row">
                            <button class="tracker-btn" @onclick="() => AdjustHp(-1)">−</button>
                            <div class="tracker-hp-display">
                                <span class="tracker-hp-current @(CurrentHp <= Hero.MaxHitPoints / 4 ? "hp-critical" : CurrentHp <= Hero.MaxHitPoints / 2 ? "hp-low" : "")">@CurrentHp</span>
                                <span class="tracker-hp-sep">/</span>
                                <span class="tracker-hp-max">@Hero.MaxHitPoints</span>
                            </div>
                            <button class="tracker-btn" @onclick="() => AdjustHp(1)">+</button>
                        </div>
                        <div class="tracker-hp-bar">
                            <div class="tracker-hp-fill @(CurrentHp <= Hero.MaxHitPoints / 4 ? "fill-critical" : CurrentHp <= Hero.MaxHitPoints / 2 ? "fill-low" : "")" style="width: @(Math.Max(0, CurrentHp * 100 / Hero.MaxHitPoints))%"></div>
                        </div>
                        <button class="tracker-reset-btn" @onclick="ResetHp">Reset to Max</button>
                    </div>

                    <!-- Spell Slots -->
                    @if (guide.SpellSlots != null)
                    {
                        <div class="tracker-block">
                            <div class="tracker-label">Spell Slots</div>
                            @foreach (var tier in guide.SpellSlots)
                            {
                                <div class="tracker-slot-row">
                                    <span class="tracker-slot-label">@tier.Label</span>
                                    <div class="tracker-pips">
                                        @for (int i = 0; i < tier.Total; i++)
                                        {
                                            var idx = i;
                                            var tierId = tier.Label;
                                            var used = SlotUsed(tierId, idx);
                                            <button class="tracker-pip @(used ? "pip-used" : "pip-avail")" @onclick="() => ToggleSlot(tierId, idx)" title="@(used ? "Expended" : "Available")"></button>
                                        }
                                    </div>
                                </div>
                            }
                            <button class="tracker-reset-btn" @onclick="ResetSlots">Reset All Slots</button>
                        </div>
                    }

                    <!-- Sorcery Points -->
                    @if (guide.SorceryPoints != null)
                    {
                        <div class="tracker-block">
                            <div class="tracker-label">Sorcery Points</div>
                            <div class="tracker-pips">
                                @for (int i = 0; i < guide.SorceryPoints.PointsPerDay; i++)
                                {
                                    var idx = i;
                                    var used = SpUsed(idx);
                                    <button class="tracker-pip tracker-pip-sp @(used ? "pip-used" : "pip-avail")" @onclick="() => ToggleSp(idx)" title="@(used ? "Spent" : "Available")"></button>
                                }
                            </div>
                            <div class="tracker-sp-count">@(guide.SorceryPoints.PointsPerDay - SpentSp.Count) / @guide.SorceryPoints.PointsPerDay remaining</div>
                            <button class="tracker-reset-btn" @onclick="ResetSp">Reset Points</button>
                        </div>
                    }

                </div>
            </div>

            <!-- Ability Scores -->
            <div class="guide-section">
                <h3>Ability Scores</h3>
                <div class="guide-abilities">
                    @foreach (var ab in GetAbilities(Hero))
                    {
                        <div class="guide-ability">
                            <div class="ability-label">@ab.Label</div>
                            <div class="ability-score">@ab.Score</div>
                            <div class="ability-mod @(ab.Mod >= 0 ? "pos" : "neg")">@FormatBonus(ab.Mod)</div>
                        </div>
                    }
                </div>
            </div>

            <!-- Saving Throws & Passive Senses -->
            <div class="guide-two-col">
                <div class="guide-section">
                    <h3>Saving Throws</h3>
                    <div class="guide-save-grid">
                        @foreach (AbilityScore ab in Enum.GetValues<AbilityScore>())
                        {
                            var prof = Hero.GetSaveProficiency(ab);
                            <div class="guide-statline @(prof ? "is-prof" : "")">
                                <span class="gsl-dot @(prof ? "on" : "")"></span>
                                <span class="gsl-bonus">@FormatBonus(Hero.GetSaveBonus(ab))</span>
                                <span class="gsl-name">@AbilityShort(ab)</span>
                            </div>
                        }
                    </div>
                </div>
                <div class="guide-section">
                    <h3>Passive Senses</h3>
                    <div class="guide-passive-grid">
                        <div class="guide-passive"><span class="gp-val">@(10 + Hero.GetSkillBonus(Skill.Perception))</span><span class="gp-lbl">Perception</span></div>
                        <div class="guide-passive"><span class="gp-val">@(10 + Hero.GetSkillBonus(Skill.Investigation))</span><span class="gp-lbl">Investigation</span></div>
                        <div class="guide-passive"><span class="gp-val">@(10 + Hero.GetSkillBonus(Skill.Insight))</span><span class="gp-lbl">Insight</span></div>
                    </div>
                </div>
            </div>

            <!-- Skills (full, live, alphabetical) -->
            <div class="guide-section">
                <h3>Skills <span class="guide-skill-legend">● proficient · ◆ expertise</span></h3>
                <div class="guide-skill-grid">
                    @foreach (var skill in Enum.GetValues<Skill>().OrderBy(s => SkillAbilityMap.DisplayName(s)))
                    {
                        var prof = Hero.GetSkillProficiency(skill);
                        var cls = prof == ProficiencyLevel.Expertise ? "is-expertise" : prof == ProficiencyLevel.Proficient ? "is-prof" : "";
                        <div class="guide-skill @cls">
                            <span class="gsk-ind">@(prof == ProficiencyLevel.Expertise ? "◆" : prof == ProficiencyLevel.Proficient ? "●" : "○")</span>
                            <span class="gsk-bonus">@FormatBonus(Hero.GetSkillBonus(skill))</span>
                            <span class="gsk-name">@SkillAbilityMap.DisplayName(skill)</span>
                            <span class="gsk-ability">@AbilityShort(SkillAbilityMap.Map[skill])</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Defenses & Special Traits -->
            @if (guide.Defenses.Length > 0)
            {
                <div class="guide-section">
                    <h3>Defenses &amp; Special Traits</h3>
                    <div class="guide-tags">
                        @foreach (var d in guide.Defenses)
                        {
                            <span class="guide-tag defense">🛡 @d</span>
                        }
                    </div>
                </div>
            }

            <!-- Actions & Spells Table -->
            <div class="guide-section">
                <h3>Actions, Attacks &amp; Spells</h3>
                <table class="guide-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Range</th>
                            <th>Effect</th>
                            <th>Uses</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var action in Hero.Actions)
                        {
                            <tr class="@GetActionRowClass(action)">
                                <td data-label="Name"><strong>@action.DisplayName</strong></td>
                                <td data-label="Type"><span class="action-type-badge @GetActionBadgeClass(action)">@GetActionTypeLabel(action)</span></td>
                                <td data-label="Range">@action.Range</td>
                                <td data-label="Effect">
                                    @if (action.ActionType == ActionType.Spell && action.SaveDC > 0)
                                    {
                                        <span class="save-dc-inline">DC @action.SaveDC @action.SaveAbility save</span>
                                        @if (!string.IsNullOrEmpty(action.Description))
                                        {
                                            <div class="action-desc">@action.Description</div>
                                        }
                                        else if (action.DamageType != DamageType.None)
                                        {
                                            <div class="action-desc">@action.DamageDice @action.DamageType damage</div>
                                        }
                                    }
                                    else if (!string.IsNullOrEmpty(action.Description))
                                    {
                                        @action.Description
                                    }
                                    else
                                    {
                                        @action.ShortSummary
                                    }
                                </td>
                                <td class="uses-cell" data-label="Uses">@GetUsesLabel(action)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Spell Descriptions -->
            @if (Hero.Spells.Any())
            {
                <div class="guide-section">
                    <h3>📖 Spells <span class="guide-skill-legend">tap a spell to read it</span></h3>
                    @foreach (var levelGroup in Hero.Spells.GroupBy(s => s.Level).OrderBy(g => g.Key))
                    {
                        <div class="spell-level-header">@(levelGroup.Key == 0 ? "Cantrips" : $"Level {levelGroup.Key}")</div>
                        @foreach (var spell in levelGroup.OrderBy(s => s.Name))
                        {
                            <div class="spell-row @(OpenSpells.Contains(spell.Id) ? "spell-expanded" : "")">
                                <div class="spell-row-main" @onclick="() => ToggleGuideSpell(spell.Id)">
                                    <span class="spell-name">@spell.Name</span>
                                    @if (spell.Concentration) { <span class="spell-tag conc-tag" title="Concentration">C</span> }
                                    @if (spell.IsRitual)       { <span class="spell-tag ritual-tag" title="Ritual">R</span> }
                                    @if (!string.IsNullOrEmpty(spell.School)) { <span class="spell-school">@spell.School</span> }
                                    <span class="spell-expand-icon">@(OpenSpells.Contains(spell.Id) ? "▲" : "▼")</span>
                                </div>
                                @if (OpenSpells.Contains(spell.Id))
                                {
                                    <div class="spell-detail">
                                        <div class="spell-meta">
                                            @if (!string.IsNullOrEmpty(spell.CastingTime)) { <span><strong>Cast:</strong> @spell.CastingTime</span> }
                                            @if (!string.IsNullOrEmpty(spell.Range))       { <span><strong>Range:</strong> @spell.Range</span> }
                                            @if (!string.IsNullOrEmpty(spell.Components))  { <span><strong>Components:</strong> @spell.Components</span> }
                                            @if (!string.IsNullOrEmpty(spell.Duration))    { <span><strong>Duration:</strong> @spell.Duration</span> }
                                        </div>
                                        @if (!string.IsNullOrEmpty(spell.Description))
                                        {
                                            <p class="spell-desc">@spell.Description</p>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            }

            <!-- Key Class Features -->
            @if (guide.ClassFeatures.Length > 0)
            {
                <div class="guide-section">
                    <h3>Key Class Features</h3>
                    <ul class="guide-features">
                        @foreach (var feat in guide.ClassFeatures)
                        {
                            <li>@feat</li>
                        }
                    </ul>
                </div>
            }

            <!-- Sorcery Points -->
            @if (guide.SorceryPoints is { } sp)
            {
                <div class="guide-section guide-sp-section">
                    <h3>🔮 Sorcery Points — @sp.PointsPerDay per Long Rest</h3>
                    <p class="sp-intro">Sorcery Points (SP) are a flexible resource. Spend them on <strong>Metamagic</strong> or convert them to/from extra spell slots via <strong>Font of Magic</strong>.</p>

                    <div class="sp-columns">

                        <!-- SP → Spell Slots -->
                        <div class="sp-box">
                            <div class="sp-box-title">🔁 SP → Spell Slot</div>
                            <div class="sp-box-note">Bonus Action — slot vanishes after Long Rest</div>
                            <table class="sp-table">
                                <thead><tr><th>Slot Level</th><th>SP Cost</th></tr></thead>
                                <tbody>
                                    <tr><td>1st</td><td>2 SP</td></tr>
                                    <tr><td>2nd</td><td>3 SP</td></tr>
                                    <tr><td>3rd</td><td>5 SP</td></tr>
                                    <tr><td>4th</td><td>6 SP</td></tr>
                                    <tr><td>5th</td><td>7 SP</td></tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Spell Slot → SP -->
                        <div class="sp-box">
                            <div class="sp-box-title">💠 Spell Slot → SP</div>
                            <div class="sp-box-note">Bonus Action — max SP gained = half your level</div>
                            <table class="sp-table">
                                <thead><tr><th>Slot Level</th><th>SP Gained</th></tr></thead>
                                <tbody>
                                    <tr><td>1st</td><td>1 SP</td></tr>
                                    <tr><td>2nd</td><td>2 SP</td></tr>
                                    <tr><td>3rd</td><td>3 SP</td></tr>
                                    <tr><td>4th</td><td>4 SP</td></tr>
                                    <tr><td>5th</td><td>5 SP</td></tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Metamagic Options -->
                        <div class="sp-box sp-box-metamagic">
                            <div class="sp-box-title">✨ Metamagic Options</div>
                            <div class="sp-box-note">Only one can be applied per spell (unless stated)</div>
                            <div class="sp-metamagic-list">
                                @foreach (var m in sp.Metamagic)
                                {
                                    <div class="sp-meta-entry">
                                        <div class="sp-meta-header">
                                            <span class="sp-meta-name">@m.Name</span>
                                            <span class="sp-meta-cost">@m.Cost SP</span>
                                        </div>
                                        <div class="sp-meta-desc">@m.Description</div>
                                    </div>
                                }
                            </div>
                        </div>

                    </div>

                    <!-- Quick Cheat Sheet -->
                    <div class="sp-cheatsheet">
                        <div class="sp-cheat-title">⚡ Quick Cheat Sheet</div>
                        @foreach (var hint in sp.CheatSheet)
                        {
                            <div class="sp-cheat-row">
                                <span class="sp-cheat-label">@hint.Scenario</span>
                                <span class="sp-cheat-arrow">→</span>
                                <span class="sp-cheat-action">@hint.Action</span>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Wild Magic Surge -->
            @if (guide.WildMagicInfo != null)
            {
                <div class="guide-section guide-wildmagic">
                    <h3>🌀 Sorcery Points &amp; Wild Magic Surges</h3>
                    <p class="wm-intro">@guide.WildMagicInfo.Intro</p>
                    <div class="wm-triggers">
                        @foreach (var t in guide.WildMagicInfo.Triggers)
                        {
                            <div class="wm-trigger-row">
                                <span class="wm-trigger-icon">⚡</span>
                                <span>@t</span>
                            </div>
                        }
                    </div>
                    @if (guide.WildMagicInfo.SurgeExamples.Length > 0)
                    {
                        <div class="wm-examples-label">Sample surge outcomes (d100):</div>
                        <div class="wm-examples">
                            @foreach (var ex in guide.WildMagicInfo.SurgeExamples)
                            {
                                <div class="wm-example">@ex</div>
                            }
                        </div>
                    }
                    <p class="wm-tip">💡 @guide.WildMagicInfo.PlayTip</p>
                </div>
            }

            <!-- Tips for Playing -->
            <div class="guide-section guide-tips">
                <h3>💡 Tips for Playing @Hero.Name</h3>
                <ul class="guide-tip-list">
                    @foreach (var tip in guide.PlayTips)
                    {
                        <li>@tip</li>
                    }
                </ul>
            </div>

        </div>
    }
    else if (Hero != null)
    {
        <div class="guide-panel">
            <div class="guide-header"><h2>@Hero.Name</h2><p class="guide-subtitle">@Hero.ClassDisplay</p></div>
            <p style="color:var(--text-dim);padding:8px 0">No quick-reference guide has been written for this character yet — but their stats, skills, and spells are on the other tabs.</p>
        </div>
    }

@code {
    [Parameter] public Character? Hero { get; set; }

    public static bool HasGuide(Guid id) => GuideData.ContainsKey(id);

    private Guid _lastId;
    protected override void OnParametersSet()
    {
        if (Hero != null && Hero.Id != _lastId)
        {
            _lastId = Hero.Id;
            ResetTracker(Hero);
        }
    }

    // ── Session Tracker ──────────────────────────────────────────────────────
    private int CurrentHp { get; set; }
    private HashSet<string> UsedSlots { get; set; } = new();
    private HashSet<int>    SpentSp   { get; set; } = new();
    private HashSet<Guid>   OpenSpells { get; set; } = new();

    private void ToggleGuideSpell(Guid id)
    {
        if (!OpenSpells.Remove(id)) OpenSpells.Add(id);
    }

    private void ResetTracker(Character c)
    {
        CurrentHp = c.MaxHitPoints;
        UsedSlots.Clear();
        SpentSp.Clear();
        OpenSpells.Clear();
    }

    private void AdjustHp(int delta)
    {
        if (Hero == null) return;
        CurrentHp = Math.Clamp(CurrentHp + delta, 0, Hero.MaxHitPoints);
    }

    private void ResetHp() { if (Hero != null) CurrentHp = Hero.MaxHitPoints; }

    private bool SlotUsed(string tier, int idx) => UsedSlots.Contains($"{tier}:{idx}");
    private void ToggleSlot(string tier, int idx)
    {
        var key = $"{tier}:{idx}";
        if (!UsedSlots.Remove(key)) UsedSlots.Add(key);
    }
    private void ResetSlots() => UsedSlots.Clear();

    private bool SpUsed(int idx) => SpentSp.Contains(idx);
    private void ToggleSp(int idx) { if (!SpentSp.Remove(idx)) SpentSp.Add(idx); }
    private void ResetSp() => SpentSp.Clear();

    // ── Helpers ─────────────────────────────────────────────────────────────

    private static string FormatBonus(int n) => n >= 0 ? $"+{n}" : $"{n}";

    private static string AbilityShort(AbilityScore a) => a switch
    {
        AbilityScore.Strength => "STR", AbilityScore.Dexterity => "DEX",
        AbilityScore.Constitution => "CON", AbilityScore.Intelligence => "INT",
        AbilityScore.Wisdom => "WIS", AbilityScore.Charisma => "CHA", _ => "?"
    };

    /// <summary>The modifier for a character's spellcasting ability (by class).</summary>
    private static int SpellAbilityMod(Character c) => c.CharacterClass.Trim().ToLowerInvariant() switch
    {
        "cleric" or "druid" or "ranger" => c.WisdomModifier,
        "wizard"                        => c.IntelligenceModifier,
        _                               => c.CharismaModifier,   // bard, paladin, sorcerer, warlock
    };

    // ── "On Your Turn" action-economy breakdown ──────────────────────────────
    private record TurnItem(string Name, string Detail, bool Highlight = false);

    /// <summary>Map a spell's casting time to an action-economy bucket.</summary>
    private static string CastingBucket(string castingTime)
    {
        var ct = castingTime.ToLowerInvariant();
        if (ct.Contains("bonus")) return "Bonus Action";
        if (ct.Contains("reaction")) return "Reaction";
        if (ct.Contains("action")) return "Action";
        return "Other";
    }

    /// <summary>Build the per-bucket turn breakdown from weapons, spells, and class features.</summary>
    private List<TurnItem> TurnItemsFor(Character c, CharacterGuideEntry guide, string bucket)
    {
        var items = new List<TurnItem>();

        // Weapon attacks are the Attack action.
        if (bucket == "Action")
        {
            foreach (var a in c.Actions.Where(a => a.ActionType == ActionType.Attack))
            {
                var dmg = string.IsNullOrEmpty(a.DamageDice) ? "" :
                    $"{a.DamageDice}{(a.DamageBonus != 0 ? FormatBonus(a.DamageBonus) : "")} {a.DamageType}";
                items.Add(new($"⚔ {a.DisplayName}", $"{FormatBonus(a.AttackBonus)} to hit · {dmg}".Trim(' ', '·')));
            }
        }

        // Spells, bucketed by casting time. Enrich with save/attack from a matching action.
        foreach (var s in c.Spells.Where(s => CastingBucket(s.CastingTime) == bucket).OrderBy(s => s.Level).ThenBy(s => s.Name))
        {
            var match = c.Actions.FirstOrDefault(a => a.Name == s.Name);
            var lvl = s.Level == 0 ? "Cantrip" : $"L{s.Level}";
            string detail;
            if (match != null && match.SaveDC > 0)
                detail = $"{lvl} · DC {match.SaveDC} {match.SaveAbility} · {match.DamageDice} {match.DamageType}".TrimEnd(' ', '·');
            else if (match != null && match.AttackBonus != 0)
                detail = $"{lvl} · {FormatBonus(match.AttackBonus)} · {match.DamageDice} {match.DamageType}".TrimEnd(' ', '·');
            else
                detail = $"{lvl} · {s.Range}".TrimEnd(' ', '·');
            items.Add(new($"✦ {s.Name}", detail));
        }

        // Curated class-feature options.
        if (guide.TurnExtras != null)
            foreach (var t in guide.TurnExtras.Where(t => t.Category == bucket))
                items.Add(new($"★ {t.Name}", t.Detail, Highlight: true));

        return items;
    }

    private static bool HasSpells(Character c) =>
        c.Actions.Any(a => a.ActionType is ActionType.Spell or ActionType.SpellAttack);

