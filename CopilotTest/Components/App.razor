<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>D&amp;D Combat Simulator</title>
    <base href="/" />
    <link rel="stylesheet" href="app.css" />
    <HeadOutlet />
</head>
<body>
    <Routes />

    @* Blazor uses this element for its reconnect UI (by id). quail-live.js watches its
       state and auto-reloads the page once the server is reachable again, so nobody
       has to manually refresh after a deploy or restart. *@
    <div id="components-reconnect-modal">
        <div class="reconnect-box">
            <h3>🎲 Reconnecting to the table…</h3>
            <p>Hold tight — this page will refresh itself as soon as the server is back.</p>
        </div>
    </div>

    <script src="_framework/blazor.web.js"></script>
    <script src="js/quail-live.js"></script>
</body>
</html>
